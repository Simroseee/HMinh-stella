local library = {}

-- 1. KHOI TAO THU VIEN GUI
function library:AddWindow(text, keybind)
    local bind = keybind or Enum.KeyCode.RightControl
    local ff = false
    
    local DoctorShiba = Instance.new("ScreenGui")
    DoctorShiba.Name = "SOMEXGUI"
    DoctorShiba.Parent = game:GetService("CoreGui")
    DoctorShiba.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    -- Nut noi mo Menu (Dành cho Mobile)
    local OpenBtn = Instance.new("ImageButton")
    OpenBtn.Parent = DoctorShiba
    OpenBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    OpenBtn.Position = UDim2.new(0.1, 0, 0.1, 0)
    OpenBtn.Size = UDim2.new(0, 50, 0, 50)
    OpenBtn.Image = "rbxassetid://33576520"
    OpenBtn.Draggable = true
    local BtnCorner = Instance.new("UICorner")
    BtnCorner.Parent = OpenBtn

    local Main = Instance.new("Frame")
    Main.Name = "Main"
    Main.Parent = DoctorShiba
    Main.AnchorPoint = Vector2.new(0.5, 0.5)
    Main.BackgroundColor3 = Color3.fromRGB(30, 28, 39)
    Main.Position = UDim2.new(0.5, 0, 0.5, 0)
    Main.Size = UDim2.new(0, 550, 0, 320)
    Main.ClipsDescendants = true
    Main.Visible = true

    -- Nut bam mo menu
    OpenBtn.MouseButton1Click:Connect(function()
        Main.Visible = not Main.Visible
    end)

    local Top = Instance.new("Frame")
    Top.Name = "Top"
    Top.Parent = Main
    Top.BackgroundTransparency = 1
    Top.Size = UDim2.new(1, 0, 0, 30)

    local Page = Instance.new("Frame")
    Page.Name = "Page"
    Page.Parent = Main
    Page.BackgroundColor3 = Color3.fromRGB(25, 23, 35)
    Page.Size = UDim2.new(0, 120, 1, 0)

    local NameHub = Instance.new("TextLabel")
    NameHub.Parent = Page
    NameHub.Text = text
    NameHub.Size = UDim2.new(1, 0, 0, 30)
    NameHub.TextColor3 = Color3.fromRGB(0, 255, 127)
    NameHub.BackgroundTransparency = 1
    NameHub.Font = Enum.Font.GothamBold

    local ScrollPage = Instance.new("ScrollingFrame")
    ScrollPage.Parent = Page
    ScrollPage.Size = UDim2.new(1, 0, 0.8, 0)
    ScrollPage.Position = UDim2.new(0, 0, 0.1, 0)
    ScrollPage.BackgroundTransparency = 1
    ScrollPage.ScrollBarThickness = 0
    local PageList = Instance.new("UIListLayout")
    PageList.Parent = ScrollPage

    local TabFolder = Instance.new("Folder")
    TabFolder.Name = "TabFolder"
    TabFolder.Parent = Main

    local uitab = {}
    function uitab:AddTab(text)
        local PageButton = Instance.new("TextButton")
        PageButton.Parent = ScrollPage
        PageButton.Size = UDim2.new(1, 0, 0, 30)
        PageButton.Text = text
        PageButton.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
        PageButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        PageButton.Font = Enum.Font.Gotham

        local MainTab = Instance.new("ScrollingFrame")
        MainTab.Parent = TabFolder
        MainTab.Size = UDim2.new(0, 420, 1, 0)
        MainTab.Position = UDim2.new(0.23, 0, 0, 0)
        MainTab.BackgroundTransparency = 1
        MainTab.Visible = false
        MainTab.ScrollBarThickness = 2
        Instance.new("UIListLayout", MainTab).Padding = UDim.new(0, 5)

        PageButton.MouseButton1Click:Connect(function()
            for _, v in pairs(TabFolder:GetChildren()) do v.Visible = false end
            MainTab.Visible = true
        end)

        if not ff then MainTab.Visible = true ff = true end

        local main = {}
        function main:AddButton(text, callback)
            local btn = Instance.new("TextButton")
            btn.Parent = MainTab
            btn.Size = UDim2.new(0, 400, 0, 35)
            btn.Text = text
            btn.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.MouseButton1Click:Connect(callback)
            Instance.new("UICorner", btn)
        end

        function main:AddToggle(text, config, callback)
            local toggled = config or false
            local tgl = Instance.new("TextButton")
            tgl.Parent = MainTab
            tgl.Size = UDim2.new(0, 400, 0, 35)
            tgl.Text = text .. (toggled and " : ON" or " : OFF")
            tgl.BackgroundColor3 = toggled and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(60, 60, 75)
            tgl.TextColor3 = Color3.fromRGB(255, 255, 255)
            tgl.MouseButton1Click:Connect(function()
                toggled = not toggled
                tgl.Text = text .. (toggled and " : ON" or " : OFF")
                tgl.BackgroundColor3 = toggled and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(60, 60, 75)
                callback(toggled)
            end)
            Instance.new("UICorner", tgl)
        end
        return main
    end
    return uitab
end

